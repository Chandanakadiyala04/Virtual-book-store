<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Virtual Book Store Test Suite"
       verbose="2"
       parallel="tests"
       thread-count="5">

    <!-- Listener registered here — applies to ALL test groups -->
    <listeners>
        <listener class-name="com.bookstore.listeners.TestListener"/>
    </listeners>

    <!-- Group 1: Unit Tests — runs in Thread 1 -->
    <test name="Unit Tests">
        <classes>
            <class name="com.bookstore.model.BookModelTest"/>
            <class name="com.bookstore.model.UserModelTest"/>
            <class name="com.bookstore.model.OrderModelTest"/>
            <class name="com.bookstore.model.ReviewModelTest"/>
            <class name="com.bookstore.model.CommunityPostModelTest"/>
            <class name="com.bookstore.model.PasswordResetTokenModelTest"/>
            <class name="com.bookstore.dto.DTOTest"/>
            <class name="com.bookstore.security.UserDetailsImplTest"/>
        </classes>
    </test>

    <!-- Group 2: Controller Tests — runs in Thread 2 -->
    <test name="Controller Tests">
        <classes>
            <class name="com.bookstore.controller.AuthControllerTest"/>
            <class name="com.bookstore.controller.BookControllerTest"/>
            <class name="com.bookstore.controller.ReviewControllerTest"/>
        </classes>
    </test>

    <!-- Group 3: Selenium Chrome — runs in Thread 3 -->
    <test name="Selenium Chrome Tests">
        <parameter name="browser" value="chrome"/>
        <classes>
            <class name="com.bookstore.selenium.SeleniumTest"/>
        </classes>
    </test>

    <!-- Group 4: Selenium Firefox — runs in Thread 4 -->
    <test name="Selenium Firefox Tests">
        <parameter name="browser" value="firefox"/>
        <classes>
            <class name="com.bookstore.selenium.SeleniumTest"/>
        </classes>
    </test>

    <!-- Group 5: Selenium Edge — runs in Thread 5 -->
    <test name="Selenium Edge Tests">
        <parameter name="browser" value="edge"/>
        <classes>
            <class name="com.bookstore.selenium.SeleniumTest"/>
        </classes>
    </test>

</suite>